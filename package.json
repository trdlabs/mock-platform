{
  "name": "trading-mock-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:contract-isolation": "tsx scripts/verify_contract_isolation.ts",
    "verify:no-forbidden-deps": "node scripts/verify_no_forbidden_deps.mjs",
    "verify:no-secrets": "tsx scripts/verify_no_secrets.ts",
    "verify:vendored-sdk": "tsx scripts/verify_vendored_sdk.ts",
    "verify:harness-sync": "node scripts/verify_harness_sync.mjs",
    "check": "pnpm typecheck && pnpm verify:contract-isolation && pnpm test",
    "check:ci": "pnpm check && pnpm verify:no-forbidden-deps && pnpm verify:no-secrets && pnpm verify:vendored-sdk && pnpm verify:harness-sync",
    "start": "node dist/src/bin/start-mock-ops.js",
    "start:research-mcp": "node dist/src/bin/start-research-mcp.js",
    "dev": "tsx src/bin/start-mock-ops.ts",
    "fetch:snapshot": "tsx tools/fetch-snapshot/fetch-snapshot.ts",
    "make:fixture": "tsx scripts/make-fixture.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.0",
    "@hono/node-ws": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@trading-platform/sdk": "https://github.com/alexnikolskiy/trading-platform-sdk/releases/download/sdk-v0.8.0/trading-platform-sdk-0.8.0.tgz",
    "ajv": "^8.20.0",
    "hono": "^4.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
